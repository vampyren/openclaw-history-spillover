{
  "name": "openclaw-history-spillover",
  "version": "0.3.0",
  "description": "Durable spillover for oversized OpenClaw chat history entries.",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test && python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:js": "node --test",
    "test:py": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "verify:patch": "python3 scripts/verify_installed_patch.py",
    "apply:patch": "python3 scripts/apply_openclaw_patch.py",
    "apply:patch:dry-run": "python3 scripts/apply_openclaw_patch.py --dry-run",
    "revert:patch": "python3 scripts/revert_openclaw_patch.py"
  },
  "keywords": [
    "openclaw",
    "history",
    "spillover",
    "transcript"
  ],
  "license": "MIT"
}
